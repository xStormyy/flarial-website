---
import features from "../../../assets/features.json"
---

<section>
    <div>
        <h2>Features</h2>
        <p>Everything you need to enhance your experience.</p>
    </div>
    <div class="list">
        {features.map((feature) => (
        <div class="feature">
            <p><strong>{feature.title}</strong></p>
            <p>{feature.description}</p>
        </div>
        ))}
    </div>
</section>

<style>
    section {
        display: flex;
        align-items: center;
        flex-direction: column;
        text-align: center;
        min-height: 100vh;
        padding: 1em;
        padding-top: 9em;
        padding-bottom: 9em;
        gap: 2em;
    }

    @media (max-width: 540px) {
        section {
            gap: 0em;
        }
    } 


    h2 {
        text-decoration: underline;
        text-decoration-color: var(--accent);
        text-decoration-thickness: 4px;
        text-underline-offset: 8px;
        margin: 0px;
        font-size: 2em;
    }

    .list {
        display: grid;
        place-items: center;
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: repeat(2, 1fr);
        gap: 2em 2em;
    }

    @media (max-width: 960px) {
        .list {
            display: grid;
            place-items: center;
            grid-template-columns: repeat(1, 1fr);
            gap: 2em 2em;
        }
    }

    .feature {
        display: flex;
        flex-direction: column;
        text-align: start;
        gap: 0.5em;
        background-color: var(--background-secondary);
        padding: 1em;
        border-radius: 1em;
    }

    .feature p {
        max-width: 32ch;
        margin: 0px;
    }
</style>
